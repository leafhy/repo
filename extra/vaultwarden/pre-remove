#!/bin/sh -e

cat <<EOF

###############################################
#                                             #
#    [ ! ]  WARNING WARNING WARNING  [ ! ]    #
#                                             #
#             REMOVING VAULTWARDEN            #
#                     WILL                    #
#                 REMOVE VAULT                #
#                                             #
###############################################

EOF

echo "Do you wish to remove Vaultwarden?"
echo -n "yes/no: "
read -r ans

if [ "$ans" = yes ]; then
    if [ -L /var/service/vaultwarden ]; then
       sv down vaultwarden
       unlink "/var/service/vaultwarden"
    fi

    deluser --remove-home vaultwarden

    rm -f \
        "/etc/vaultwarden.conf" \
        "/var/log/vaultwarden.log"

    rm -rf \
        "/etc/sv/vaultwarden" \
        "/run/runit/supervise.vaultwarden"

elif [ "$ans" != yes ]
    echo "Aborting Vaultwarden removal."
    exit 1
fi
